    # Archivo de configuración de variables de entorno
# Copia este archivo a .env y completa con tus valores

# API de Groq (para transcripción de audio)
# Obtener en: https://console.groq.com/
GROQ_API_KEY=tu_api_key_aqui

# Configuración del modelo BERT
DEFAULT_MODEL_TYPE=multilingual

# Configuración de la aplicación
DEBUG=False
LOG_LEVEL=INFO

# Umbrales de clasificación (0.0 - 1.0)
HIGH_RISK_THRESHOLD=0.70
MODERATE_RISK_THRESHOLD=0.50

# Configuración de Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
